# Server Monitor Agent Configuration
# Copy this file to /etc/server-agent/server-agent.env and fill in the values

# Required: URL of the ingest endpoint
INGEST_URL=https://monitor.mcpick.link/api/ingest

# Required: API key for authenticating with the ingest endpoint
INGEST_API_KEY=your-api-key

# Optional: Collection interval (default: 5s)
# COLLECTION_INTERVAL=5s

# Optional: Server hostname (default: system hostname)
# HOSTNAME=my-server

# Optional: Server ID (default: auto-generated UUID)
# SERVER_ID=my-unique-server-id
