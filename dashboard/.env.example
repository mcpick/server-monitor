# Server Monitor Dashboard Configuration
# Copy this file to .env and fill in the values

# Required: Turso database URL (server-side only, not exposed to client)
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Required: Turso authentication token (server-side only, not exposed to client)
TURSO_AUTH_TOKEN=your-auth-token

# Required: Authentication username
AUTH_USERNAME=admin

# Required: PBKDF2 hash of the authentication password
# Generate with: node -e "const s=crypto.getRandomValues(new Uint8Array(16));crypto.subtle.importKey('raw',new TextEncoder().encode('YOUR_PASSWORD'),'PBKDF2',false,['deriveBits']).then(k=>crypto.subtle.deriveBits({name:'PBKDF2',salt:s,iterations:600000,hash:'SHA-256'},k,256)).then(h=>console.log('pbkdf2:600000:'+Buffer.from(s).toString('base64')+':'+Buffer.from(h).toString('base64')))"
AUTH_PASSWORD_HASH=pbkdf2:600000:base64salt:base64hash

# Required: Secret key for JWT signing (use a random 256-bit key)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-256-bit-secret-key
