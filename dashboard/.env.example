# Server Monitor Dashboard Configuration
# Copy this file to .env and fill in the values

# Required: Turso database URL
VITE_TURSO_DATABASE_URL=libsql://your-database.turso.io

# Required: Turso authentication token
VITE_TURSO_AUTH_TOKEN=your-auth-token

# Required: Authentication username
VITE_AUTH_USERNAME=admin

# Required: SHA-256 hash of the authentication password
# Generate with: echo -n "your-password" | shasum -a 256 | cut -d' ' -f1
VITE_AUTH_PASSWORD_HASH=your-password-hash
