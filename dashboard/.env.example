# Server Monitor Dashboard Configuration
# Copy this file to .env and fill in the values

# Required: Turso database URL (server-side only, not exposed to client)
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Required: Turso authentication token (server-side only, not exposed to client)
TURSO_AUTH_TOKEN=your-auth-token

# Required: Authentication username
AUTH_USERNAME=admin

# Required: bcrypt hash of the authentication password
# Generate with: npx bcrypt-cli hash your-password
AUTH_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here

# Required: Secret key for JWT signing (use a random 256-bit key)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-256-bit-secret-key
